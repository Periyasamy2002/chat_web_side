# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=chat-web-side.onrender.com,localhost,127.0.0.1

# Database (SQLite for simplicity, change for production)
# For PostgreSQL: postgresql://user:password@localhost:5432/chatdb

# Admin Registration
# Optional: Set this to require a secret key for admin registration after first admin is created
ADMIN_SECRET_KEY=your-admin-secret-key-here

# Default Admin User (auto-created if no admin exists)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=Admin@Secure123

# Gemini API (for translation)
GEMINI_API_KEY=your-gemini-api-key-here

# Email (Optional - for production)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Session Settings
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# Render Deployment
RENDER=True
